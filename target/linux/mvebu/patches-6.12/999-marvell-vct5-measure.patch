--- a/drivers/net/phy/marvell.c.orig	2026-03-03 22:26:50.629051071 +0100
+++ b/drivers/net/phy/marvell.c	2026-03-03 22:30:59.230147958 +0100
@@ -2213,16 +2213,28 @@
 	int i;
 	int val;
 
-	for (i = 0; i < 32; i++) {
+	ktime_t start, ready;
+	s64 elapsed_ns;
+
+	start = ktime_get();
+
+	for (i = 0; i < 10000; i++) {
 		val = __phy_read(phydev, MII_VCT5_CTRL);
